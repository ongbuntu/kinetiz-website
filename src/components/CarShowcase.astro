---
const stats = [
  { label: "Top speed", value: 295, decimals: 0, unit: "KM / H", accent: "cyan" },
  { label: "0 — 100 km / h", value: 2.6, decimals: 1, unit: "SECONDS", accent: "coral" },
  { label: "Sensors", value: 14, decimals: 0, unit: "7 CAM · 3 LIDAR · 4 RADAR", accent: "cyan" },
  { label: "AI decisions", value: 1000, decimals: 0, suffix: "+", unit: "PER SECOND", accent: "coral" },
];

const callouts = [
  {
    n: "01",
    title: "Sensor stack",
    body: "7 cameras, 3 LiDAR, 4 radar — full 360° perception feeding the loop at race pace.",
  },
  {
    n: "02",
    title: "Autonomy compute",
    body: "Onboard cluster runs the full driving stack at 1,000+ Hz, no link to the pit.",
  },
  {
    n: "03",
    title: "Dallara EAV-25",
    body: "Super Formula chassis adapted for autonomous racing — A2RL spec, 2026 build.",
  },
  {
    n: "04",
    title: "Race tyres",
    body: "Slicks tuned for hot-lap pace at Imola and Yas Marina. No driver, full grip.",
  },
];
---

<section id="car" class="relative bg-kin-bg border-t border-kin-line overflow-hidden">
  <div
    aria-hidden="true"
    class="absolute inset-0 telemetry-grid opacity-30 pointer-events-none"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 py-20 lg:py-28">
    <!-- Section header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 reveal">
      <div>
        <span class="label">// The car · 2026 spec</span>
        <h2 class="headline text-5xl md:text-7xl lg:text-8xl mt-3 leading-[0.9]">
          The<br /><span class="text-kin-coral text-glow-coral">Kinetiz car.</span>
        </h2>
      </div>
      <p class="text-base md:text-lg text-white/70 max-w-md leading-relaxed">
        Dallara EAV-25 Super Formula chassis. Autonomous from the ground up.
        Built to race the limit — no driver, no hesitation.
      </p>
    </div>

    <!-- Car stage with scanning HUD -->
    <div class="relative reveal" style="--reveal-delay: 100ms">
      <div
        aria-hidden="true"
        class="absolute inset-x-0 top-1/4 h-2/3 bg-kin-cyan/10 blur-3xl pointer-events-none"
      >
      </div>

      <div class="grid lg:grid-cols-12 gap-6 lg:gap-8 items-center relative">
        <!-- Left callouts -->
        <div class="lg:col-span-3 grid grid-cols-2 lg:grid-cols-1 gap-4 order-2 lg:order-1">
          {
            callouts.slice(0, 2).map((c, i) => (
              <div
                class="hud-frame border border-kin-line p-4 bg-kin-surface/50 backdrop-blur hover:border-kin-cyan/50 transition-colors reveal"
                style={`--reveal-delay: ${150 + i * 80}ms`}
              >
                <div class="flex items-baseline gap-3 mb-2">
                  <span class="readout text-xs text-kin-cyan font-bold tracking-widest">
                    {c.n}
                  </span>
                  <span class="text-sm font-bold tracking-tight">{c.title}</span>
                </div>
                <p class="text-xs text-white/60 leading-relaxed">{c.body}</p>
              </div>
            ))
          }
        </div>

        <!-- Car image with scan -->
        <div class="lg:col-span-6 relative order-1 lg:order-2 scanline">
          <img
            src="/images/Kinetiz_Side.png"
            alt="Kinetiz autonomous race car, side profile in 2026 livery"
            class="w-full h-auto object-contain drop-shadow-[0_20px_60px_rgba(127,212,212,0.18)]"
            loading="lazy"
          />
          <!-- crosshair reticle -->
          <div
            aria-hidden="true"
            class="absolute top-4 right-4 readout text-[10px] tracking-[0.2em] text-kin-cyan/70 border border-kin-cyan/30 px-2 py-1"
          >
            SYS · LIVE
          </div>
        </div>

        <!-- Right callouts -->
        <div class="lg:col-span-3 grid grid-cols-2 lg:grid-cols-1 gap-4 order-3">
          {
            callouts.slice(2, 4).map((c, i) => (
              <div
                class="hud-frame border border-kin-line p-4 bg-kin-surface/50 backdrop-blur hover:border-kin-coral/50 transition-colors reveal"
                style={`--reveal-delay: ${150 + i * 80}ms`}
              >
                <div class="flex items-baseline gap-3 mb-2">
                  <span class="readout text-xs text-kin-coral font-bold tracking-widest">
                    {c.n}
                  </span>
                  <span class="text-sm font-bold tracking-tight">{c.title}</span>
                </div>
                <p class="text-xs text-white/60 leading-relaxed">{c.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Stats grid with count-up -->
    <div class="mt-16 lg:mt-20 reveal">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-kin-line border border-kin-line">
        {
          stats.map((s, i) => (
            <div
              class="px-5 py-7 lg:py-9 flex flex-col gap-2 group hover:bg-kin-surface/40 transition-colors reveal"
              style={`--reveal-delay: ${i * 70}ms`}
            >
              <span class="label">{s.label}</span>
              <span
                data-count-to={s.value}
                data-count-decimals={s.decimals}
                data-count-suffix={s.suffix ?? ""}
                class={
                  "readout font-black text-5xl lg:text-7xl tracking-[-0.04em] leading-none " +
                  (s.accent === "coral" ? "text-kin-coral" : "text-kin-cyan")
                }
              >
                0
              </span>
              <span class="label text-white/50">{s.unit}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
