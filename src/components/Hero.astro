---
const NEXT_RACE = {
  name: "Imola",
  country: "Italy",
  date: "2026-09-05T11:00:00Z",
  label: "A2RL Round 1 — Europe debut",
};

const stats = [
  { label: "Next race", value: "IMOLA", sub: "05 SEP 2026", accent: "coral" },
  { label: "Top speed", value: "295", sub: "KM / H", accent: "cyan", count: { to: 295 } },
  { label: "Podiums", value: "3", sub: "2025 SEASON", accent: "cyan", count: { to: 3 } },
  { label: "World ranking", value: "P4", sub: "A2RL S2 FINAL", accent: "coral" },
];

// HUD sensor markers laid over the car — verified spec (7 cam · 3 LiDAR · 4 radar)
const markers = [
  { label: "LiDAR ×3", x: "44%", y: "30%", accent: "cyan" },
  { label: "Camera ×7", x: "63%", y: "44%", accent: "coral" },
  { label: "Radar ×4", x: "30%", y: "58%", accent: "cyan" },
];

// Telemetry ticker — verified facts only
const ticker = [
  "AUTONOMOUS F1",
  "A2RL SEASON 3",
  "TOP SPEED 295 KM/H",
  "0–100 IN 2.6S",
  "14 SENSORS ONBOARD",
  "1,000+ DECISIONS / SEC",
  "DALLARA EAV-25",
  "P4 IN THE WORLD",
  "SIM-SPRINT GRAND CHAMPION",
];
---

<section
  id="hero"
  class="relative overflow-hidden min-h-dvh flex flex-col justify-between"
  data-race-date={NEXT_RACE.date}
>
  <!-- ── Background stack ───────────────────────────── -->
  <!-- Faint technical grid -->
  <div
    aria-hidden="true"
    class="absolute inset-0 telemetry-grid opacity-50 pointer-events-none"
  >
  </div>

  <!-- Perspective grid floor receding to horizon -->
  <div
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 h-[55%] overflow-hidden pointer-events-none"
  >
    <div class="perspective-grid absolute inset-0"></div>
  </div>

  <!-- Ambient color orbs -->
  <div
    aria-hidden="true"
    class="absolute -top-32 -right-24 w-[520px] h-[520px] rounded-full bg-kin-coral/15 blur-3xl pointer-events-none"
  >
  </div>
  <div
    aria-hidden="true"
    class="absolute top-1/3 -left-40 w-[560px] h-[560px] rounded-full bg-kin-cyan/10 blur-3xl pointer-events-none"
  >
  </div>

  <!-- Car backdrop + sensor HUD -->
  <div
    aria-hidden="true"
    class="absolute inset-y-0 right-0 w-full lg:w-[68%] pointer-events-none"
  >
    <div class="relative h-full w-full">
      <img
        src="/images/Kinetiz_3_4%202.png"
        alt=""
        class="absolute inset-0 w-full h-full object-contain object-right scale-110 lg:scale-100 opacity-25 lg:opacity-90 animate-float"
        style="mask-image: linear-gradient(to left, black 55%, transparent 96%); -webkit-mask-image: linear-gradient(to left, black 55%, transparent 96%);"
        loading="eager"
        fetchpriority="high"
      />
      <!-- Sensor markers (desktop only — they track the car art) -->
      <div class="hidden lg:block">
        {
          markers.map((m) => (
            <div
              class="absolute -translate-x-1/2 -translate-y-1/2"
              style={`left:${m.x}; top:${m.y};`}
            >
              <span
                class={
                  "relative flex w-2.5 h-2.5 " +
                  (m.accent === "coral" ? "text-kin-coral" : "text-kin-cyan")
                }
              >
                <span
                  class="live-dot absolute inset-0 rounded-full"
                  style={`background:${m.accent === "coral" ? "#E84C5C" : "#7FD4D4"}`}
                />
                <span
                  class="absolute inset-0 rounded-full"
                  style={`background:${m.accent === "coral" ? "#E84C5C" : "#7FD4D4"}`}
                />
              </span>
              <span
                class={
                  "absolute left-4 top-1/2 -translate-y-1/2 whitespace-nowrap readout text-[10px] font-bold tracking-[0.18em] px-2 py-1 border bg-kin-bg/70 backdrop-blur-sm " +
                  (m.accent === "coral"
                    ? "text-kin-coral border-kin-coral/40"
                    : "text-kin-cyan border-kin-cyan/40")
                }
              >
                {m.label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Left-side readability vignette -->
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-r from-kin-bg via-kin-bg/70 to-transparent pointer-events-none"
  >
  </div>
  <div
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-kin-bg to-transparent pointer-events-none"
  >
  </div>

  <!-- ── Foreground content ──────────────────────────── -->
  <div
    class="relative max-w-7xl w-full mx-auto px-6 lg:px-10 pt-28 lg:pt-32 pb-10 flex-1 flex flex-col"
  >
    <!-- Status row -->
    <div
      class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-auto reveal"
    >
      <div
        class="inline-flex items-center gap-3 self-start border border-kin-line bg-kin-surface/40 backdrop-blur-sm px-3.5 py-2 hud-frame"
      >
        <span class="relative inline-flex w-2 h-2">
          <span
            class="live-dot absolute inset-0 rounded-full bg-kin-coral"
            aria-hidden="true"></span>
          <span class="absolute inset-0 rounded-full bg-kin-coral"></span>
        </span>
        <span class="label !text-white/80">Autonomous F1 · A2RL Season 3</span>
      </div>

      <div
        class="self-start md:self-auto border border-kin-line bg-kin-surface/40 backdrop-blur-sm px-4 py-2.5 hud-frame"
      >
        <div class="label !text-[0.6rem]">T-minus to {NEXT_RACE.name}</div>
        <div
          id="countdown"
          class="readout text-xl md:text-2xl font-bold text-kin-cyan text-glow-cyan mt-0.5"
        >
          — : — : — : —
        </div>
      </div>
    </div>

    <!-- Headline -->
    <h1
      class="headline text-[18vw] md:text-[12vw] lg:text-[10rem] xl:text-[11rem] leading-[0.85] mt-10 reveal"
      style="--reveal-delay: 80ms"
    >
      <span class="block text-kin-cyan text-glow-cyan">RACING</span>
      <span class="block">BEYOND</span>
      <span class="block text-kin-coral text-glow-coral">LIMITS.</span>
    </h1>

    <!-- Sub copy + CTAs -->
    <div
      class="mt-10 md:mt-14 grid md:grid-cols-12 gap-6 md:gap-10 items-end reveal"
      style="--reveal-delay: 160ms"
    >
      <p
        class="md:col-span-6 text-base md:text-lg text-white/80 max-w-xl leading-relaxed"
      >
        Kinetiz is an autonomous racing team competing in the
        <span class="text-white font-semibold"
          >Abu Dhabi Autonomous Racing League</span
        >. Our AI driver makes
        <span class="text-kin-cyan font-semibold"
          >1,000+ decisions per second</span
        > from inside the cockpit — pushing the edge of what a car without a human
        can do.
      </p>
      <div class="md:col-span-6 flex flex-wrap gap-3 md:justify-end">
        <a
          href="#car"
          class="group inline-flex items-center gap-2 bg-kin-cyan text-black px-5 py-3 font-semibold tracking-tight hover:bg-kin-cyan-bright transition-all hover:glow-cyan"
        >
          Meet the car
          <span
            aria-hidden="true"
            class="transition-transform group-hover:translate-x-1">→</span
          >
        </a>
        <a
          href="#calendar"
          class="inline-flex items-center gap-2 border border-kin-line text-white px-5 py-3 font-semibold tracking-tight hover:border-kin-coral hover:text-kin-coral transition-colors"
        >
          2026 calendar
        </a>
      </div>
    </div>
  </div>

  <!-- ── Telemetry ticker ─────────────────────────────── -->
  <div
    class="relative border-y border-kin-line bg-kin-surface/40 backdrop-blur-sm py-2.5 ticker-mask"
    aria-hidden="true"
  >
    <div class="ticker-track">
      {
        [0, 1].map(() => (
          <div class="flex items-center">
            {ticker.map((t) => (
              <span class="readout text-[11px] font-medium tracking-[0.2em] text-white/55 px-6 flex items-center gap-6">
                {t}
                <span class="text-kin-cyan">/</span>
              </span>
            ))}
          </div>
        ))
      }
    </div>
  </div>

  <!-- ── Stats strip ──────────────────────────────────── -->
  <div class="relative border-b border-kin-line">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div
        class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-kin-line border-x border-kin-line"
      >
        {
          stats.map((s, i) => (
            <div
              class="px-5 py-6 lg:py-8 flex flex-col gap-2 reveal group hover:bg-kin-surface/30 transition-colors"
              style={`--reveal-delay: ${i * 70}ms`}
            >
              <span class="label">{s.label}</span>
              {s.count ? (
                <span
                  data-count-to={s.count.to}
                  class={
                    "readout font-black text-5xl lg:text-6xl tracking-[-0.04em] leading-none " +
                    (s.accent === "coral" ? "text-kin-coral" : "text-kin-cyan")
                  }
                >
                  0
                </span>
              ) : (
                <span
                  class={
                    "font-black text-5xl lg:text-6xl tracking-[-0.04em] leading-none " +
                    (s.accent === "coral" ? "text-kin-coral" : "text-kin-cyan")
                  }
                >
                  {s.value}
                </span>
              )}
              <span class="label text-white/50">{s.sub}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const section = document.getElementById("hero");
  const el = document.getElementById("countdown");
  if (section && el) {
    const target = new Date(section.dataset.raceDate as string).getTime();
    const pad = (n: number) =>
      String(Math.max(0, Math.floor(n))).padStart(2, "0");

    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        el.textContent = "LIGHTS OUT";
        return;
      }
      const d = diff / (1000 * 60 * 60 * 24);
      const h = (diff / (1000 * 60 * 60)) % 24;
      const m = (diff / (1000 * 60)) % 60;
      const s = (diff / 1000) % 60;
      el.textContent = `${pad(d)}d ${pad(h)}h ${pad(m)}m ${pad(s)}s`;
    };
    tick();
    setInterval(tick, 1000);
  }
</script>
