---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kinetiz Racing — Racing Beyond Limits",
  description = "Kinetiz: autonomous racing team competing in the A2RL series. P4 in the world, 2025 SIM-Sprint Grand Champion.",
} = Astro.props;

const nav = [
  { label: "Team", href: "#hero" },
  { label: "Updates", href: "#sparkz" },
  { label: "K1", href: "#car" },
  { label: "Track Record", href: "#achievements" },
  { label: "Calendar", href: "#calendar" },
  { label: "Sponsors", href: "#sponsors" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-kin-bg text-white antialiased min-h-screen flex flex-col">
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-kin-bg/70 border-b border-kin-line">
      <div class="max-w-7xl mx-auto px-6 lg:px-10 h-16 flex items-center justify-between">
        <a href="#hero" class="flex items-center gap-2 group">
          <span class="text-xl font-black tracking-tight">
            <span class="text-kin-cyan">KIN</span><span class="text-kin-coral">ETIZ</span>
          </span>
        </a>
        <nav class="hidden md:flex items-center gap-7">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class="label hover:text-white transition-colors"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <a
          href="https://instagram.com/kinetiz.ai"
          target="_blank"
          rel="noopener noreferrer"
          class="label border border-kin-line px-3 py-1.5 rounded-full hover:border-kin-cyan hover:text-kin-cyan transition-colors"
        >
          @kinetiz.ai
        </a>
      </div>
    </header>

    <main class="flex-1 pt-16">
      <slot />
    </main>

    <footer class="border-t border-kin-line mt-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-10 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <div class="text-lg font-black tracking-tight">
            <span class="text-kin-cyan">KIN</span><span class="text-kin-coral">ETIZ</span>
          </div>
          <p class="label mt-2">Racing beyond limits</p>
        </div>
        <div class="flex flex-col md:flex-row gap-2 md:gap-6 text-sm text-kin-mute">
          <span>A2RL Season 2 — P4 in the world</span>
          <a
            href="https://instagram.com/kinetiz.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-kin-cyan transition-colors"
            >@kinetiz.ai</a
          >
          <span>© {new Date().getFullYear()} Kinetiz Racing</span>
        </div>
      </div>
    </footer>
  </body>
</html>
