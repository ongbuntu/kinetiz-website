---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kinetiz Racing — Racing Beyond Limits",
  description = "Kinetiz: autonomous racing team competing in the A2RL series. P4 in the world, 2025 SIM-Sprint Grand Champion.",
} = Astro.props;

const nav = [
  { label: "Team", href: "#hero" },
  { label: "Updates", href: "#sparkz" },
  { label: "The car", href: "#car" },
  { label: "Track Record", href: "#achievements" },
  { label: "Calendar", href: "#calendar" },
  { label: "Sponsors", href: "#sponsors" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#060708" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/kinetiz_livery_2026.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-kin-bg text-white antialiased min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:bg-kin-cyan focus:text-black focus:px-4 focus:py-2 focus:font-semibold"
    >
      Skip to content
    </a>

    <header
      id="site-header"
      class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent"
    >
      <div
        class="max-w-7xl mx-auto px-6 lg:px-10 h-16 flex items-center justify-between"
      >
        <a href="#hero" class="flex items-center gap-2.5 group">
          <img
            src="/images/logo.png"
            alt="Kinetiz"
            width="32"
            height="32"
            class="w-8 h-8 object-contain transition-transform duration-300 group-hover:scale-110"
          />
          <span class="text-xl font-black tracking-tight">
            <span class="text-kin-cyan">KIN</span><span class="text-kin-coral"
              >ETIZ</span
            >
          </span>
        </a>

        <nav id="primary-nav" class="hidden md:flex items-center gap-7">
          {
            nav.map((item) => (
              <a
                href={item.href}
                data-nav-link={item.href}
                class="label hover:text-white transition-colors relative py-1"
              >
                {item.label}
              </a>
            ))
          }
        </nav>

        <div class="flex items-center gap-3">
          <a
            href="https://instagram.com/kinetiz.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden sm:inline-flex label border border-kin-line px-3 py-1.5 rounded-full hover:border-kin-cyan hover:text-kin-cyan transition-colors"
          >
            @kinetiz.ai
          </a>
          <button
            id="menu-toggle"
            type="button"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
            class="md:hidden inline-flex flex-col justify-center gap-1.5 w-10 h-10 items-center border border-kin-line rounded-md hover:border-kin-cyan transition-colors"
          >
            <span
              class="menu-bar block w-5 h-px bg-white transition-all duration-300"
            ></span>
            <span
              class="menu-bar block w-5 h-px bg-white transition-all duration-300"
            ></span>
            <span
              class="menu-bar block w-5 h-px bg-white transition-all duration-300"
            ></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile menu overlay -->
    <div
      id="mobile-menu"
      class="fixed inset-0 z-40 bg-kin-bg/97 backdrop-blur-xl flex-col items-center justify-center gap-2 hidden"
    >
      <nav class="flex flex-col items-center gap-6 text-center">
        {
          nav.map((item) => (
            <a
              href={item.href}
              data-mobile-link
              class="headline text-3xl text-white/80 hover:text-kin-cyan transition-colors"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <a
        href="https://instagram.com/kinetiz.ai"
        target="_blank"
        rel="noopener noreferrer"
        class="label border border-kin-line px-4 py-2 rounded-full hover:border-kin-cyan hover:text-kin-cyan transition-colors mt-10"
      >
        @kinetiz.ai →
      </a>
    </div>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="relative border-t border-kin-line mt-24 overflow-hidden">
      <div
        aria-hidden="true"
        class="absolute inset-0 telemetry-grid opacity-40 pointer-events-none"
      >
      </div>
      <div
        class="relative max-w-7xl mx-auto px-6 lg:px-10 py-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-8"
      >
        <div class="flex items-center gap-3">
          <img
            src="/images/logo.png"
            alt="Kinetiz"
            width="36"
            height="36"
            class="w-9 h-9 object-contain"
          />
          <div>
            <div class="text-lg font-black tracking-tight">
              <span class="text-kin-cyan">KIN</span><span class="text-kin-coral"
                >ETIZ</span
              >
            </div>
            <p class="label mt-1">Racing beyond limits</p>
          </div>
        </div>

        <div class="flex items-center gap-2.5 readout text-xs text-kin-mute">
          <span class="relative inline-flex w-2 h-2">
            <span
              class="live-dot absolute inset-0 rounded-full bg-kin-cyan"
              aria-hidden="true"></span>
            <span class="absolute inset-0 rounded-full bg-kin-cyan"></span>
          </span>
          <span class="text-kin-cyan/80">ALL SYSTEMS NOMINAL</span>
        </div>

        <div
          class="flex flex-col md:flex-row gap-2 md:gap-6 text-sm text-kin-mute"
        >
          <span>A2RL Season 2 — P4 in the world</span>
          <a
            href="https://instagram.com/kinetiz.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-kin-cyan transition-colors">@kinetiz.ai</a
          >
          <span>© {new Date().getFullYear()} Kinetiz Racing</span>
        </div>
      </div>
    </footer>

    <script>
      // ── Header scroll state ───────────────────────────────
      const header = document.getElementById("site-header");
      const onScroll = () => {
        if (!header) return;
        if (window.scrollY > 12) {
          header.classList.add(
            "bg-kin-bg/80",
            "backdrop-blur-md",
            "border-kin-line",
          );
        } else {
          header.classList.remove(
            "bg-kin-bg/80",
            "backdrop-blur-md",
            "border-kin-line",
          );
        }
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      // ── Mobile menu ───────────────────────────────────────
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const bars = document.querySelectorAll<HTMLElement>(".menu-bar");
      const setMenu = (open: boolean) => {
        if (!menu || !toggle) return;
        menu.classList.toggle("hidden", !open);
        menu.classList.toggle("flex", open);
        toggle.setAttribute("aria-expanded", String(open));
        toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        document.body.style.overflow = open ? "hidden" : "";
        // hamburger → X
        bars[0]?.classList.toggle("translate-y-[7px]", open);
        bars[0]?.classList.toggle("rotate-45", open);
        bars[1]?.classList.toggle("opacity-0", open);
        bars[2]?.classList.toggle("-translate-y-[7px]", open);
        bars[2]?.classList.toggle("-rotate-45", open);
      };
      toggle?.addEventListener("click", () =>
        setMenu(menu?.classList.contains("hidden") ?? true),
      );
      menu
        ?.querySelectorAll("[data-mobile-link]")
        .forEach((l) => l.addEventListener("click", () => setMenu(false)));
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setMenu(false);
      });

      // ── Scroll reveal ─────────────────────────────────────
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      const revealEls = document.querySelectorAll<HTMLElement>(".reveal");
      if (prefersReduced || !("IntersectionObserver" in window)) {
        revealEls.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );
        revealEls.forEach((el) => io.observe(el));
      }

      // ── Count-up on first view ────────────────────────────
      const fmt = (n: number, decimals: number) =>
        n.toLocaleString("en-US", {
          minimumFractionDigits: decimals,
          maximumFractionDigits: decimals,
        });
      const runCount = (el: HTMLElement) => {
        const to = parseFloat(el.dataset.countTo || "0");
        const decimals = parseInt(el.dataset.countDecimals || "0", 10);
        const suffix = el.dataset.countSuffix || "";
        if (prefersReduced) {
          el.textContent = fmt(to, decimals) + suffix;
          return;
        }
        const dur = 1400;
        let start: number | null = null;
        const step = (t: number) => {
          if (start === null) start = t;
          const p = Math.min((t - start) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = fmt(to * eased, decimals) + suffix;
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = fmt(to, decimals) + suffix;
        };
        requestAnimationFrame(step);
      };
      const counters =
        document.querySelectorAll<HTMLElement>("[data-count-to]");
      if (!("IntersectionObserver" in window)) {
        counters.forEach(runCount);
      } else {
        const co = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                runCount(entry.target as HTMLElement);
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.5 },
        );
        counters.forEach((el) => co.observe(el));
      }

      // ── Scroll spy (active nav link) ──────────────────────
      const navLinks =
        document.querySelectorAll<HTMLElement>("[data-nav-link]");
      const sections = Array.from(navLinks)
        .map((l) => document.querySelector(l.dataset.navLink || ""))
        .filter(Boolean) as HTMLElement[];
      if (sections.length && "IntersectionObserver" in window) {
        const spy = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const id = "#" + entry.target.id;
                navLinks.forEach((l) =>
                  l.classList.toggle(
                    "!text-kin-cyan",
                    l.dataset.navLink === id,
                  ),
                );
              }
            });
          },
          { rootMargin: "-45% 0px -50% 0px" },
        );
        sections.forEach((s) => spy.observe(s));
      }
    </script>
  </body>
</html>
